<%- layout('layouts/boilerplate') %>

    <section class="admin-register-section">

        <div class="container">

            <div class="admin-register-wrapper">

                <!-- LEFT SIDE -->

                <div class="admin-register-info">

                    <div class="admin-register-icon">
                        <i class="fas fa-building"></i>
                    </div>

                    <h2>Join Annam as an NGO</h2>

                    <p>
                        Register your organization on the Annam platform
                        and help connect surplus food with communities
                        that need it most.
                    </p>

                    <div class="admin-register-info-item">
                        <i class="fas fa-check-circle"></i>
                        <span>Manage food donations</span>
                    </div>

                    <div class="admin-register-info-item">
                        <i class="fas fa-hand-holding-heart"></i>
                        <span>Support communities in need</span>
                    </div>

                    <div class="admin-register-info-item">
                        <i class="fas fa-chart-line"></i>
                        <span>Track donation activity</span>
                    </div>

                </div>


                <!-- RIGHT SIDE -->

                <div class="admin-register-card">

                    <div class="admin-register-heading">

                        <span class="admin-register-small-title">
                            JOIN OUR NETWORK
                        </span>

                        <h2>Register Your NGO</h2>

                        <p>Enter your organization details below.</p>

                    </div>


                    <form action="/login" method="POST" novalidate class="needs-validation">


                        <!-- USERNAME -->

                        <div class="admin-register-input-group">

                            <label for="username">
                                <i class="fas fa-user"></i>
                                Username
                            </label>

                            <input id="username" type="text" name="username" class="form-control"
                                placeholder="Enter your username" required>

                            <div class="valid-feedback">
                                Looks Good!
                            </div>

                            <div class="invalid-feedback">
                                Enter your username!
                            </div>

                        </div>






                        <!-- PASSWORD -->

                        <div class="admin-register-input-group">

                            <label for="password">
                                <i class="fas fa-lock"></i>
                                Password
                            </label>

                            <input id="password" type="password" name="password" class="form-control"
                                placeholder="Enter your password" required>

                            <div class="valid-feedback">
                                Looks Good!
                            </div>

                            <div class="invalid-feedback">
                                Enter your password!
                            </div>

                        </div>


                        <button type="submit" class="admin-register-submit-btn">

                            <i class="fas fa-user-plus"></i>

                            Register NGO

                        </button>

                    </form>

                </div>

            </div>

        </div>

    </section>


    <script>
        (function () {

            'use strict';

            const forms =
                document.querySelectorAll('.needs-validation');

            Array.from(forms).forEach(form => {

                form.addEventListener('submit', event => {

                    if (!form.checkValidity()) {

                        event.preventDefault();

                        event.stopPropagation();

                    }

                    form.classList.add('was-validated');

                });

            });

        })();
    </script>