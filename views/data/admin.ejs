<%- layout('layouts/boilerplate') %>

    <div class="admin-dashboard">

        <!-- ==========================
         ADMIN SIDEBAR
    =========================== -->

        <aside class="admin-sidebar">



            <nav class="admin-menu">

                <a href="#dashboard" class="active">

                    <i class="fas fa-chart-pie"></i>

                    Dashboard

                </a>


                <a href="#donations">

                    <i class="fas fa-box"></i>

                    Donations

                </a>


                <a href="#volunteers">

                    <i class="fas fa-users"></i>

                    Volunteers

                </a>


                <a href="#reports">

                    <i class="fas fa-chart-line"></i>

                    Reports

                </a>


                <a href="/">

                    <i class="fas fa-house"></i>

                    Website

                </a>

            </nav>

        </aside>



        <!-- ==========================
         MAIN CONTENT
    =========================== -->

        <main class="admin-main">


            <!-- ADMIN NAVBAR -->

            <div class="admin-navbar">

                <div>

                    <h3>Admin Dashboard</h3>

                    <p>
                        Food Donation Platform Management System
                    </p>

                </div>


                <div class="admin-profile">

                    <div class="notification-icon">

                        <i class="fas fa-bell"></i>

                        <span>4</span>

                    </div>


                    <div>

                        <strong>
                            <%= data.username %>
                        </strong>

                    </div>


                    <div class="admin-avatar">

                        <i class="fas fa-user-shield"></i>

                    </div>

                </div>

            </div>



            <!-- ==========================
             DASHBOARD STATS
        =========================== -->

            <section id="dashboard">
                <div class="row g-3">
                    <div class="col-xl col-md">
                        <div class="admin-stat-card">
                            <div>
                                <p>Total Volunteers</p>
                                <h2>
                                    <%= data.volunteers.length %>
                                </h2>
                            </div>
                            <div class="admin-stat-icon bg-warning">
                                <i class="fas fa-users"></i>
                            </div>
                        </div>
                    </div>

                    <div class="col-xl col-md col-sm">
                        <div class="admin-stat-card">
                            <div>
                                <p>Meals Distributed</p>
                                <h2>
                                    <%= data.meals_distributed.length %>
                                </h2>
                            </div>
                            <div class="admin-stat-icon bg-danger">
                                <i class="fas fa-bowl-food"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </section>
            <!-- ==========================
             ADMIN INFORMATION CARDS
        =========================== -->

            <div class="row g-4">


                <!-- RECENT DONATIONS -->


                <div class="col-xl-8">

                    <section id="donations" class="admin-section">

                        <div class="admin-section-header">

                            <div>

                                <h3>Recent Donations</h3>

                                <p>
                                    Latest food donation activity.
                                </p>

                            </div>


                            <button class="btn btn-outline-success">

                                View All

                            </button>

                        </div>


                        <div class="admin-card">

                            <div class="table-responsive">
                                <table class="table align-middle admin-table">
                                    <thead>
                                        <tr>
                                            <th>Donation ID</th>
                                            <th>Food</th>
                                            <th>Type</th>
                                            <th>Location</th>
                                            <th>Pickup Time</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% for (let donation of donations) { %>
                                            <tr>
                                                <td>
                                                    <%= donation._id %>
                                                </td>
                                                <td>
                                                    <%= donation.quantity %>
                                                </td>
                                                <td>
                                                    <%= donation.foodType %>
                                                </td>
                                                <td>
                                                    <%= donation.location %>
                                                </td>
                                                <td>
                                                    <%= donation.pickupTime %>
                                                </td>
                                            </tr>
                                            <% } %>


                                    </tbody>

                                </table>

                            </div>

                        </div>

                    </section>

                </div>





            </div>
