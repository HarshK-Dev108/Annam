<%- layout('layouts/boilerplate') %>

<section class="donation-form-section">
    <div class="container">

        <div class="donation-form-wrapper">

            <!-- LEFT SIDE -->
            <div class="donation-form-info">

                <div class="donation-info-icon">
                    <i class="fas fa-hand-holding-heart"></i>
                </div>

                <h2>Share Food, Spread Hope</h2>

                <p>
                    Register your surplus food donation and help us connect
                    it with NGOs and communities that need it most.
                </p>

                <div class="donation-info-item">
                    <i class="fas fa-check-circle"></i>
                    <span>Quick donation registration</span>
                </div>

                <div class="donation-info-item">
                    <i class="fas fa-truck"></i>
                    <span>Easy pickup coordination</span>
                </div>

                <div class="donation-info-item">
                    <i class="fas fa-users"></i>
                    <span>Support communities in need</span>
                </div>

            </div>


            <!-- RIGHT SIDE -->
            <div class="donation-form-card">

                <div class="donation-form-heading">

                    <span class="donation-small-title">
                        MAKE A DIFFERENCE
                    </span>

                    <h2>Register a Donation</h2>

                    <p>Enter the food donation details below.</p>

                </div>


                <form action="/donate"
                      method="POST"
                      novalidate
                      class="needs-validation">


                    <!-- QUANTITY -->

                    <div class="donation-input-group">

                        <label for="quantity">
                            <i class="fas fa-box-open"></i>
                            Food & Quantity
                        </label>

                        <input
                            id="quantity"
                            type="text"
                            name="donate[quantity]"
                            class="form-control"
                            placeholder="Example: 50 packed meals"
                            required>

                        <div class="valid-feedback">
                            Looks Good!
                        </div>

                        <div class="invalid-feedback">
                            Enter the food and quantity!
                        </div>

                    </div>


                    <!-- PICKUP TIME -->

                    <div class="donation-input-group">

                        <label for="pickupTime">
                            <i class="fas fa-clock"></i>
                            Pickup Time
                        </label>

                        <input
                            id="pickupTime"
                            type="time"
                            name="donate[pickupTime]"
                            class="form-control"
                            required>

                        <div class="valid-feedback">
                            Looks Good!
                        </div>

                        <div class="invalid-feedback">
                            Pickup time is required!
                        </div>

                    </div>


                    <!-- FOOD TYPE -->

                    <div class="donation-input-group">

                        <label for="foodType">
                            <i class="fas fa-utensils"></i>
                            Food Type
                        </label>

                        <select
                            id="foodType"
                            name="donate[foodType]"
                            class="form-select"
                            required>

                            <option value="" selected disabled>
                                Select food type
                            </option>

                            <option value="veg">Vegetarian</option>

                            <option value="non-veg">Non-Vegetarian</option>

                        </select>

                        <div class="valid-feedback">
                            Looks Good!
                        </div>

                        <div class="invalid-feedback">
                            Select the food type!
                        </div>

                    </div>


                    <!-- LOCATION -->

                    <div class="donation-input-group">

                        <label for="location">
                            <i class="fas fa-location-dot"></i>
                            Pickup Location
                        </label>

                        <input
                            id="location"
                            type="text"
                            name="donate[location]"
                            class="form-control"
                            placeholder="Enter pickup location"
                            required>

                        <div class="valid-feedback">
                            Looks Good!
                        </div>

                        <div class="invalid-feedback">
                            Enter the pickup location!
                        </div>

                    </div>


                    <button
                        type="submit"
                        class="donation-submit-btn">

                        <i class="fas fa-heart"></i>

                        Register Donation

                    </button>

                </form>

            </div>

        </div>

    </div>
</section>


<script>

(function () {

    'use strict';

    const forms =
        document.querySelectorAll('.needs-validation');

    Array.from(forms).forEach(form => {

        form.addEventListener('submit', event => {

            if (!form.checkValidity()) {

                event.preventDefault();

                event.stopPropagation();

            }

            form.classList.add('was-validated');

        });

    });

})();

</script>